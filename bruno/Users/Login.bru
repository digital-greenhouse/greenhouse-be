meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{base_url}}/users/login
  body: json
  auth: none
}

body:json {
  {
    "email": "julian@example.com",
    "password": "password123"
  }
}

script:post-response {
  if (res.status === 200 && res.body.token) {
    bru.setEnvVar("token", res.body.token);
  }
}
