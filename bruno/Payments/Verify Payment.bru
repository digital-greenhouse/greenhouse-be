meta {
  name: Verify Payment
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/payments/1/verify
  body: json
  auth: bearer
}

body:json {
  {
    "status": "VERIFIED",
    "rejection_reason": ""
  }
}

docs {
  ### Verificar Pago (Admin/Owner)
  Permite al dueño o administrador validar un pago.
  
  **Resultados:**
  - `VERIFIED`: La reserva pasa a `CONFIRMED`.
  - `REJECTED`: La reserva pasa a `CANCELLED`, liberando las fechas.
}
