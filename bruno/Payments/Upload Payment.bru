meta {
  name: Upload Payment
  type: http
  seq: 1
}

post {
  url: {{base_url}}/payments/upload
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
}

body:json {
  {
    "booking_id": 3,
    "amount": 250000.00,
    "payment_method": "TRANSFERENCIA",
    "proof_data": "BASE64_IMAGE_DATA_HERE",
    "proof_mime_type": "image/jpeg"
  }
}
